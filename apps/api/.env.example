# Node environment: development | production | test
NODE_ENV=development

# Port the API listens on
PORT=3002

# Postgres connection used by the running app (Prisma driver adapter).
# Local dev/test: same as DIRECT_URL, pointing at the docker-compose Postgres.
# Staging/production: Supabase's POOLED connection string (Supavisor/PgBouncer, port 6543).
#   Example: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://bearnance:bearnance@localhost:5433/bearnance

# Postgres connection used by Prisma CLI (migrate/generate) only.
# Local dev/test: same as DATABASE_URL.
# Staging/production: Supabase's DIRECT connection string (port 5432, no pooler) —
# required because the pooler doesn't support the prepared statements migrations need.
#   Example: postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DIRECT_URL=postgresql://bearnance:bearnance@localhost:5433/bearnance

# Supabase project URL — used to verify Supabase-issued auth JWTs. The JWKS endpoint
# (<SUPABASE_URL>/auth/v1/.well-known/jwks.json) is derived from this, so projects using
# asymmetric signing keys (ES256/RS256) need only this value.
SUPABASE_URL=https://your-project-ref.supabase.co

# Optional — set ONLY if the project still signs tokens with the legacy symmetric HS256
# secret (Project Settings > JWT Keys > Legacy JWT Secret). Leave empty for projects on
# asymmetric signing keys, which are verified via JWKS.
SUPABASE_JWT_SECRET=

# Supabase secret (service) key — SERVER-SIDE ONLY. Reserved for admin operations (e.g. the
# Supabase Admin API). Not required today: users are provisioned from verified JWT claims.
# Never expose to the browser/mobile and never commit a real value.
SUPABASE_SECRET_KEY=

# Origin of the web app, used for CORS
WEB_APP_URL=http://localhost:3000
