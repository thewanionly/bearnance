{
  "extends": "@bearnance/typescript-config/react-library.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["node", "vite/client", "vitest/config"]
  },
  "include": [
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "../../packages/ui-mobile/src/**/*.ts",
    "../../packages/ui-mobile/src/**/*.tsx",
    "../../packages/ui-web/src/**/*.ts",
    "../../packages/ui-web/src/**/*.tsx",
    "vite.config.ts",
    "vitest.shims.d.ts"
  ],
  "exclude": ["node_modules", "storybook-static"]
}
