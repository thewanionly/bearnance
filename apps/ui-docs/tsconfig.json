{
  "extends": "@bearnance/typescript-config/react-library.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["node", "vite/client", "jest", "@testing-library/jest-dom"]
  },
  "include": [
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "../../packages/ui-mobile/src/**/*.ts",
    "../../packages/ui-mobile/src/**/*.tsx",
    "../../packages/ui-web/src/**/*.ts",
    "../../packages/ui-web/src/**/*.tsx",
    "jest.config.ts",
    "jest.setup.ts"
  ],
  "exclude": [
    "node_modules",
    "storybook-static",
    "../../packages/*/src/**/*.spec.ts",
    "../../packages/*/src/**/*.spec.tsx",
    "../../packages/*/src/**/*.test.ts",
    "../../packages/*/src/**/*.test.tsx"
  ]
}
