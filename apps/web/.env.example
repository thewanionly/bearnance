# Supabase auth (client). NOT NEXT_PUBLIC_ prefixed — read at runtime on the server
# (src/lib/supabase-env.ts) and passed to the browser client, so a single Docker image
# works across environments. The publishable key is public by design; the secret/service
# key must NEVER live here.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
