{
  "name": "web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "imports": {
    "#components/*": "./src/components/*.tsx",
    "#hooks/*": "./src/hooks/*.ts",
    "#lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings 0",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "check-types": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@bearnance/ui-web": "workspace:*",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@bearnance/eslint-config": "workspace:*",
    "@bearnance/prettier-config": "workspace:*",
    "@bearnance/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "^10.6.0",
    "prettier": "^3.7.4",
    "tailwindcss": "^4",
    "typescript": "6.0.3"
  }
}
