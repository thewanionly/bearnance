{
  "name": "@bearnance/ui-core",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    "./avatar": "./src/avatar.ts",
    "./button": "./src/button.ts",
    "./icon": "./src/icon.ts",
    "./input": "./src/input.ts",
    "./layout": "./src/layout.ts",
    "./list-item": "./src/list-item.ts",
    "./modal": "./src/modal.ts",
    "./navigation": "./src/navigation.ts"
  },
  "scripts": {
    "gen:icons": "node --experimental-strip-types scripts/generate-icons.ts",
    "check:icons": "node --experimental-strip-types scripts/generate-icons.ts --check",
    "lint": "eslint . --max-warnings 0",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "check-types": "pnpm check:icons && tsc --noEmit"
  },
  "dependencies": {
    "@bearnance/design-tokens": "workspace:*"
  },
  "devDependencies": {
    "@bearnance/eslint-config": "workspace:*",
    "@bearnance/prettier-config": "workspace:*",
    "@bearnance/typescript-config": "workspace:*",
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "@types/node": "^22.15.3",
    "eslint": "^10.6.0",
    "prettier": "^3.7.4",
    "typescript": "6.0.3"
  }
}
