{
  "name": "@bearnance/ui-web",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "imports": {
    "#components/*": "./src/components/*/*.tsx",
    "#hooks/*": "./src/hooks/*.ts",
    "#lib/*": "./src/lib/*.ts",
    "#styles/*": "./src/styles/*"
  },
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./components/*": "./src/components/*/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:watch": "jest --watch",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@bearnance/eslint-config": "workspace:*",
    "@bearnance/jest-config": "workspace:*",
    "@bearnance/prettier-config": "workspace:*",
    "@bearnance/typescript-config": "workspace:*",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "^10.6.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "prettier": "^3.7.4",
    "ts-node": "^10.9.2",
    "ts-jest": "^29.4.0",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@bearnance/design-tokens": "workspace:*",
    "@bearnance/ui-core": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  }
}
