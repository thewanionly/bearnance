{
  "name": "@bearnance/ui-mobile",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "imports": {
    "#components/*": "./src/components/*/*.tsx",
    "#hooks/*": "./src/hooks/*.ts",
    "#lib/*": "./src/lib/*.ts"
  },
  "exports": {
    "./components/*": "./src/components/*/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:watch": "jest --watch",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.2.3",
    "react-native": ">=0.78"
  },
  "dependencies": {
    "@bearnance/design-tokens": "workspace:*",
    "@bearnance/ui-core": "workspace:*"
  },
  "devDependencies": {
    "@bearnance/eslint-config": "workspace:*",
    "@bearnance/jest-config": "workspace:*",
    "@bearnance/prettier-config": "workspace:*",
    "@bearnance/typescript-config": "workspace:*",
    "@jest/globals": "^29.7.0",
    "@react-native/babel-preset": "0.86.0",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/react-native": "^14.0.1",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "babel-jest": "^29.7.0",
    "eslint": "^10.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.7.4",
    "react": "^19.2.7",
    "react-native": "0.86.0",
    "test-renderer": "^1.2.0",
    "ts-node": "^10.9.2",
    "typescript": "6.0.3"
  }
}
