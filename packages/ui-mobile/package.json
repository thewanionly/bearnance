{
  "name": "@bearnance/ui-mobile",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "imports": {
    "#components/*": "./src/components/*/*.tsx",
    "#hooks/*": "./src/hooks/*.ts",
    "#lib/*": "./src/lib/*.ts"
  },
  "exports": {
    "./components/*": "./src/components/*/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@bearnance/eslint-config": "workspace:*",
    "@bearnance/prettier-config": "workspace:*",
    "@bearnance/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "eslint": "^10.6.0",
    "prettier": "^3.7.4",
    "typescript": "6.0.3"
  }
}
