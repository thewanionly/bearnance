{
  "name": "@bearnance/jest-config",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    "./base": {
      "types": "./base.d.ts",
      "import": "./base.js",
      "default": "./base.js"
    },
    "./mocks/file": "./mocks/file.cjs",
    "./mocks/react-native": "./mocks/react-native.tsx",
    "./mocks/style": "./mocks/style.cjs",
